{
  "id": "djtouchette.test-on-save",
  "name": "Test on Save",
  "apiVersion": "1",
  "version": "1.1.0",
  "server": {
    "command": "node",
    "args": [
      "server.js"
    ],
    "port": 9207,
    "health": "/health"
  },
  "panes": [
    {
      "type": "djtouchette.test-on-save",
      "title": "Test on Save",
      "icon": "\ud83e\uddea",
      "scope": "agent",
      "path": "/"
    }
  ],
  "settings": [
    {
      "key": "testCommand",
      "label": "Test command",
      "type": "string",
      "default": "npm test",
      "help": "Command run on change."
    },
    {
      "key": "debounceMs",
      "label": "Debounce (ms)",
      "type": "number",
      "default": 1500,
      "help": "Wait this long after the last change before running."
    },
    {
      "key": "notify",
      "label": "Notification center updates",
      "type": "boolean",
      "default": true,
      "help": "Post fail/recover updates to the in-app notification center (one slot per project)."
    }
  ],
  "capabilities": [
    "agents.sendMessage"
  ],
  "emits": [
    "notify.post"
  ],
  "consumes": [
    "fs.changed",
    "agent.state_changed",
    "agent.snapshot"
  ]
}
